APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# local dev: STORAGE_DISK=public  |  production: STORAGE_DISK=s3
STORAGE_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (local dev: use Mailpit — https://github.com/axllent/mailpit) ---
# Start Mailpit: mailpit  (SMTP on :1025, web UI on http://127.0.0.1:8025)
# Production: swap MAIL_MAILER=smtp and fill host/credentials for Mailgun or SES
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@pawsconnect.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Vonage SMS (https://dashboard.nexmo.com) ---
# Used for application-approved and home-visit-scheduled SMS notifications.
# Adopters can opt in under Settings → Profile.
VONAGE_KEY=your-vonage-api-key
VONAGE_SECRET=your-vonage-api-secret
VONAGE_SMS_FROM="PawsConnect"

# Mailgun (production)
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=your-domain.mailgun.org
# MAILGUN_SECRET=key-xxxxx

# Amazon SES (production)
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# --- S3 / Object Storage (set STORAGE_DISK=s3 to activate) ---
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket-name
# Leave AWS_URL blank for standard S3; set for Cloudflare R2 or custom CDN
AWS_URL=
# Leave AWS_ENDPOINT blank for standard S3; set for R2 or MinIO
AWS_ENDPOINT=
# Set true for R2/MinIO (path-style) — false for standard S3 (virtual-hosted style)
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
